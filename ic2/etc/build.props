  src/json_io.scala \
  src/endpoint.scala \
  src/iq.scala \
  src/daemon.scala \
  src/client.scala \
  src/ic2.scala \
  src/test_tool.scala \
  src/tools.scala
services = \
  isabelle.ic2.Tools
